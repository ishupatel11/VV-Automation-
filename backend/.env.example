# =============================================================================
# .env.example — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your real values.
#
#   cp .env.example .env
#
# NEVER commit the .env file to Git. It is listed in .gitignore.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# MySQL connection string.
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
#
# Examples:
#   Local:    mysql+pymysql://root:password@localhost:3306/vv_automation
#   Railway:  mysql+pymysql://root:xxxx@containers-us-west-xx.railway.app:xxxx/railway
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/vv_automation

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Your Gmail address (used to SEND the notification emails)
GMAIL_USER=your_gmail@gmail.com

# Gmail App Password — NOT your regular Gmail password!
# Generate at: https://myaccount.google.com/apppasswords
# Steps: Google Account → Security → 2-Step Verification → App Passwords
#        → Select app: "Mail" → Select device: "Other" → Generate
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# The email address that will RECEIVE contact form notifications
# Can be the same as GMAIL_USER or a different address
RECIPIENT_EMAIL=your_gmail@gmail.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Netlify/Vercel URL once deployed.
# For local dev: http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-site.netlify.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max contact form submissions per IP per 60 seconds
RATE_LIMIT_PER_MINUTE=5

# ── App Config ────────────────────────────────────────────────────────────────
# "development" enables Swagger UI (/docs) and SQL query logging
# "production" disables both
APP_ENV=development
APP_NAME=VV Automation Contact API
APP_VERSION=1.0.0
